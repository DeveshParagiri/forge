#!/bin/sh
# Bootstrap Forge from the default branch, then build and install it.
set -eu

REPO_URL="${GROK_REPO_URL:-https://github.com/DeveshParagiri/forge.git}"
BRANCH="${GROK_BRANCH:-${GROK_DEV_BRANCH:-main}}"
DEFAULT_SOURCE_DIR="$HOME/.local/share/grok/source"
UPDATER="${GROK_UPDATER:-$HOME/bin/grok-update-from-source}"

# When executed from a checkout, build that checkout. When piped through sh,
# clone into the managed source directory instead.
SCRIPT_DIR=""
case "$0" in
  */*) SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" 2>/dev/null && pwd) || true ;;
esac
if [ -n "${GROK_SRC:-}" ]; then
  SOURCE_DIR="$GROK_SRC"
elif [ -n "$SCRIPT_DIR" ] && [ -d "$SCRIPT_DIR/../.git" ]; then
  SOURCE_DIR=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
else
  SOURCE_DIR="$DEFAULT_SOURCE_DIR"
fi

if ! command -v git >/dev/null 2>&1; then
  echo "BLOCKED: git is not installed. Install Git and retry."
  exit 1
fi

if ! command -v cargo >/dev/null 2>&1; then
  echo "BLOCKED: cargo is not installed. Run https://rustup.rs and retry."
  exit 1
fi

if ! command -v dotslash >/dev/null 2>&1 && ! command -v protoc >/dev/null 2>&1; then
  echo "BLOCKED: dotslash or protoc is not installed. Install either one and retry."
  exit 1
fi

if [ -e "$SOURCE_DIR" ] && [ ! -d "$SOURCE_DIR/.git" ]; then
  echo "BLOCKED: $SOURCE_DIR exists but is not a Git checkout."
  exit 1
fi

if [ ! -d "$SOURCE_DIR/.git" ]; then
  echo "==> cloning Forge ($BRANCH) into $SOURCE_DIR"
  mkdir -p "$(dirname "$SOURCE_DIR")"
  git clone --branch "$BRANCH" --single-branch "$REPO_URL" "$SOURCE_DIR"
else
  origin_url="$(git -C "$SOURCE_DIR" remote get-url origin 2>/dev/null || true)"
  if [ -z "$origin_url" ]; then
    echo "BLOCKED: existing checkout at $SOURCE_DIR has no origin remote."
    exit 1
  fi

  # Protect the managed curl-install checkout from accidentally using an
  # unrelated repository. Explicit GROK_SRC and direct-checkout installs are
  # allowed to use forks or alternate remotes.
  if [ "$SOURCE_DIR" = "$DEFAULT_SOURCE_DIR" ] && [ -z "${GROK_SRC:-}" ]; then
    expected_url="${REPO_URL%.git}"
    actual_url="${origin_url%.git}"
    legacy_url="https://github.com/DeveshParagiri/grok-build"
    if [ "$actual_url" = "$legacy_url" ]; then
      echo "==> migrating origin from grok-build to Forge"
      git -C "$SOURCE_DIR" remote set-url origin "$REPO_URL"
    elif [ "$actual_url" != "$expected_url" ]; then
      echo "BLOCKED: existing checkout at $SOURCE_DIR has an unexpected origin: $origin_url"
      exit 1
    fi
  fi

  echo "==> using existing checkout at $SOURCE_DIR"
fi

mkdir -p "$(dirname "$UPDATER")"
install -m 755 "$SOURCE_DIR/scripts/grok-update-from-source" "$UPDATER"

GROK_SRC="$SOURCE_DIR" GROK_BRANCH="$BRANCH" exec "$UPDATER"
